# Prism/Minecraft runtime state. Keep the instance metadata in git, but keep
# the game directory disposable.
/minecraft/*
!/minecraft/.gitkeep
!/minecraft/mods/
/minecraft/mods/*
!/minecraft/mods/*-local.jar

# Local source checkouts and built mod jars.
/local-mods/
/mod-sources/
/tools/dev-env.local.json
*.jar
!/minecraft/mods/*-local.jar
*.mrpack
*.zip

# Build and tool caches.
/.gradle/
/build/
/.packwizserver/
/tools/bin/
__pycache__/

# Codex/app-local workspace state.
/.agents/
/.codex/

# Logs and editor noise.
*.log
.DS_Store
Thumbs.db
.idea/
.vscode/
